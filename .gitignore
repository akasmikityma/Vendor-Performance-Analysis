# -----------------------------
# Ignore raw / unwanted data
# -----------------------------
data/
raw/
logs/

# Ignore all CSVs by default
*.csv

# -----------------------------
# Allow Sample Data (nested)
# -----------------------------
!Sample Data/
!Sample Data/**/
!Sample Data/**/*.csv

# -----------------------------
# Jupyter
# -----------------------------
.ipynb_checkpoints/

# -----------------------------
# Python cache
# -----------------------------
__pycache__/
*.pyc

# -----------------------------
# OS junk
# -----------------------------
.DS_Store
Thumbs.db
__MACOSX/

# -----------------------------
# Ignore misc
# -----------------------------
*.txt
Screenshot_*.png

# -----------------------------
# Explicitly allow important files
# -----------------------------
!*.ipynb
!*.py
!*.pdf
!*.pbix
!*.md
!.gitignore